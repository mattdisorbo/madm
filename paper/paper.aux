\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Actual accuracy versus self-estimated accuracy for each model across four datasets. Points above the diagonal indicate overconfidence (self-estimated $>$ actual). Across 224 model $\times $ condition pairs, 153 (68\%) are overconfident. The direction of miscalibration varies by model: some are predominantly overconfident, others underconfident.}}{7}{figure.caption.9}\protected@file@percent }
\newlabel{fig:overconfidence}{{4}{7}{Actual accuracy versus self-estimated accuracy for each model across four datasets. Points above the diagonal indicate overconfidence (self-estimated $>$ actual). Across 224 model $\times $ condition pairs, 153 (68\%) are overconfident. The direction of miscalibration varies by model: some are predominantly overconfident, others underconfident}{figure.caption.9}{}}
