\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces SFT with chain-of-thought reasoning on full scenario prompts. The model is trained on three datasets and evaluated on all four main datasets, including the held-out MovieLens. Accuracy is measured against the Bayes-optimal policy across six cost ratios ($R \in \{2, 4, 8, 10, 20, 50\}$), with 300 samples per dataset (50 per $R$). MoralMachine results are reported in Appendix~\ref {app:moral}.}}{13}{table.caption.17}\protected@file@percent }
\newlabel{tab:sft_results}{{3}{13}{SFT with chain-of-thought reasoning on full scenario prompts. The model is trained on three datasets and evaluated on all four main datasets, including the held-out MovieLens. Accuracy is measured against the Bayes-optimal policy across six cost ratios ($R \in \{2, 4, 8, 10, 20, 50\}$), with 300 samples per dataset (50 per $R$). MoralMachine results are reported in Appendix~\ref {app:moral}}{table.caption.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Implicit escalation threshold $p^*$ (left) and self-estimated accuracy $\hat  {a}$ (right) for each model. The threshold $p^*$ varies widely (56\% to over 100\%), while self-estimated accuracy ranges from 79\% to 97\%. The dotted lines show the optimal threshold at cost ratio $R = 4$ (left) and average actual accuracy (right).}}{13}{figure.caption.18}\protected@file@percent }
\newlabel{fig:pstar}{{5}{13}{Implicit escalation threshold $p^*$ (left) and self-estimated accuracy $\hat {a}$ (right) for each model. The threshold $p^*$ varies widely (56\% to over 100\%), while self-estimated accuracy ranges from 79\% to 97\%. The dotted lines show the optimal threshold at cost ratio $R = 4$ (left) and average actual accuracy (right)}{figure.caption.18}{}}
